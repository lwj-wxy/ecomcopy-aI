# Example env file
# Copy to .env.local and fill real values locally. Do not commit .env.local.

# Public
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_PADDLE_CLIENT_TOKEN=<set_paddle_client_side_token>

# AI providers (server-side)
DEEPSEEK_API_KEY=<set_in_env_local>
GEMINI_API_KEY=<set_in_env_local>

# Paddle billing (server-side)
PADDLE_ENV=sandbox
PADDLE_API_KEY=<set_in_env_local>
PADDLE_WEBHOOK_SECRET=<set_in_env_local>
PADDLE_PRICE_STARTER=<set_starter_price_id>
PADDLE_PRICE_PRO=<set_pro_price_id>
# Optional: approved payment-link domain only.
# Leave empty to use Paddle Dashboard "Default payment link".
PADDLE_CHECKOUT_URL=

# Firebase Admin (for server webhook writes)
FIREBASE_ADMIN_PROJECT_ID=<set_project_id>
FIREBASE_ADMIN_CLIENT_EMAIL=<set_service_account_email>
FIREBASE_ADMIN_PRIVATE_KEY=<set_private_key_with_escaped_newlines>
FIREBASE_DATABASE_ID=<set_firestore_database_id_if_not_default>
# Optional alternative (use one method only):
# FIREBASE_ADMIN_CREDENTIALS_JSON=<set_full_service_account_json_single_line>
